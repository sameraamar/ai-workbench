# =============================================================================
# UI Configuration (Streamlit)
# Copy this file to .env and customize for your setup
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_PYTHONPATH=src

# -----------------------------------------------------------------------------
# Model & Backend Configuration
# -----------------------------------------------------------------------------
# Model ID (must match what model-serving is running)
MODEL_ID=google/gemma-4-E2B-it

# Default system prompt for the UI
MODEL_SYSTEM_PROMPT=You are a helpful assistant. Answer with concise, robust, direct, and short responses.

# URL to the model-serving backend
MODEL_SERVING_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Shared media directory
# ---------------------------------------------------------------------------
# Uploaded files (images, video, audio, PDFs, …) are stored here.
# This folder MUST be accessible from both:
#   • Windows (this process) — set the Windows path here
#   • WSL2 / vLLM backend    — set the SAME folder as SHARED_MEDIA_DIR
#                               in vllm-serving/.env.vllm (expressed as /mnt/c/…)
# When both sides point to the same physical folder, the model reads files
# directly via file:// URIs instead of receiving base64-encoded payloads.
# If they do not match, file-based media delivery will silently fail.
SHARED_MEDIA_DIR=C:\ai-workbench\shared-media
