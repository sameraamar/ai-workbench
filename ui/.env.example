# =============================================================================
# UI Configuration (Streamlit)
# Copy this file to .env and customize for your setup
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_PYTHONPATH=src

# -----------------------------------------------------------------------------
# Model & Backend Configuration
# -----------------------------------------------------------------------------
# Model ID (must match what model-serving is running)
GEMMA_MODEL_ID=google/gemma-4-E2B-it

# Default system prompt for the UI
GEMMA_SYSTEM_PROMPT=You are a helpful assistant. Answer with concise, robust, direct, and short responses. Do not elaborate unless the user asks for more detail.

# URL to the model-serving backend
GEMMA_SERVING_URL=http://localhost:8000
