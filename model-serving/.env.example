# =============================================================================
# Model Serving Configuration
# Copy this file to .env and customize for your setup
# =============================================================================

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
GEMMA_MODEL_ID=google/gemma-4-E2B-it
GEMMA_FORCE_DOWNLOAD=0
GEMMA_MODEL_CACHE_DIR=

# -----------------------------------------------------------------------------
# GPU Configuration
# See docs/gpu-selection-guide.md for detailed configuration options
# -----------------------------------------------------------------------------
# Force CPU-only mode (1=true, 0=false)
GEMMA_FORCE_CPU=0
# Use specific GPU by ID (0, 1, 2, etc. or leave empty for auto)
GEMMA_GPU_ID=
# Device mapping strategy ("auto", "cpu", or custom mapping)
GEMMA_DEVICE_MAP=auto
# Enable 4-bit quantization
# - DISABLE (0) for Gemma 4 E2B/E4B on RTX 3090 — testing showed 21% speed loss, model fits fine at BF16
# - ENABLE  (1) for large models that exceed GPU VRAM: Mistral 24B (~48 GB BF16 → ~12 GB 4-bit), Gemma 26B/31B, Mistral 119B
GEMMA_QUANTIZE_4BIT=0

# -----------------------------------------------------------------------------
# Performance Optimizations
# -----------------------------------------------------------------------------
# Enable PyTorch compilation for faster inference (1=true, 0=false)
GEMMA_TORCH_COMPILE=1
# Enable Flash Attention if available (1=true, 0=false)
# On Windows native: flash-attn has no prebuilt wheels; falls back to SDPA (PyTorch built-in, memory-efficient).
# On Linux/WSL2: install flash-attn for ~10-30% faster long-sequence inference.
GEMMA_FLASH_ATTENTION=1
# Enable memory optimizations (1=true, 0=false)
GEMMA_MEMORY_OPT=1
# Enable inference optimizations (1=true, 0=false)
GEMMA_INFERENCE_OPT=1
# PyTorch compile mode ("default", "reduce-overhead", "max-autotune")
GEMMA_COMPILE_MODE=default
# Maximum input tokens before the server truncates long prompts from the left.
# Prevents CUDA OOM on long inputs when flash_attn is not installed (SDPA mode).
# Default 8192 is safe on 24 GB fp16. Raise to 16384 for long-document use cases.
GEMMA_MAX_INPUT_TOKENS=8192

# -----------------------------------------------------------------------------
# HuggingFace Configuration
# -----------------------------------------------------------------------------
HF_HUB_DISABLE_SYMLINKS_WARNING=1
# Optional: HuggingFace token for private models
HF_TOKEN=

# -----------------------------------------------------------------------------
# Advanced Configuration
# -----------------------------------------------------------------------------
# Gateway mode: "gemma" = real model inference (required for actual use)
#               "stub"  = returns empty responses, useful for API contract testing only
GEMMA_FASTAPI_GATEWAY=gemma
