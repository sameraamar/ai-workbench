# ==============================================================================
# Model Serving Configuration — vLLM Backend
# ==============================================================================
# vLLM runs inside WSL2 and exposes an OpenAI-compatible API on localhost.
# This .env is loaded by start.ps1 and start.sh.

# ---------------------------------------------------------------------------
# Default model to serve (HuggingFace model ID)
# ---------------------------------------------------------------------------
MODEL_ID=google/gemma-4-E2B-it

# ---------------------------------------------------------------------------
# Server configuration
# ---------------------------------------------------------------------------
VLLM_HOST=0.0.0.0
VLLM_PORT=8000

# ---------------------------------------------------------------------------
# GPU / VRAM settings
# ---------------------------------------------------------------------------
# Maximum sequence length (context window). Lower = less VRAM.
MAX_MODEL_LEN=8192

# Fraction of GPU VRAM to use (0.0 – 1.0). Leave headroom for the OS.
GPU_MEMORY_UTILIZATION=0.90

# Data type: bfloat16 (default), float16, auto
DTYPE=bfloat16

# Quantization method: none, awq, gptq, bitsandbytes
# Use "awq" for models that exceed GPU VRAM at full precision.
QUANTIZATION=none

# Tensor parallelism (number of GPUs). 1 for single-GPU setups.
TENSOR_PARALLEL_SIZE=1

# ---------------------------------------------------------------------------
# Model-specific overrides
# ---------------------------------------------------------------------------
# Mistral models require special tokenizer/config format.
# These are auto-detected by start.sh based on MODEL_ID.

# Maximum images per prompt (for multimodal models)
# vLLM 0.19+ requires JSON format. Value must be single-quoted for bash.
LIMIT_MM_PER_PROMPT='{"image": 24}'

# ---------------------------------------------------------------------------
# HuggingFace Configuration
# ---------------------------------------------------------------------------
HF_TOKEN=
