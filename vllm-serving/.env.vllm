# ==============================================================================
# Model Serving Configuration — vLLM Backend
# ==============================================================================
# vLLM runs inside WSL2 and exposes an OpenAI-compatible API on localhost.
# This .env is loaded by start.ps1 and start.sh.

# ---------------------------------------------------------------------------
# Default model to serve (HuggingFace model ID)
# ---------------------------------------------------------------------------
MODEL_ID=google/gemma-4-E2B-it

# ---------------------------------------------------------------------------
# Server configuration
# ---------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
VLLM_PORT=8000

# ---------------------------------------------------------------------------
# GPU / VRAM settings
# ---------------------------------------------------------------------------
# Maximum sequence length (context window). Lower = less VRAM.
MAX_MODEL_LEN=8192

# Fraction of GPU VRAM to use (0.0 – 1.0). Leave headroom for the OS.
GPU_MEMORY_UTILIZATION=0.90

# Data type: bfloat16 (default), float16, auto
DTYPE=bfloat16

# Quantization method: none, awq, gptq, bitsandbytes
# Use "awq" for models that exceed GPU VRAM at full precision.
QUANTIZATION=none

# Tensor parallelism (number of GPUs). 1 for single-GPU setups.
TENSOR_PARALLEL_SIZE=1

# ---------------------------------------------------------------------------
# KV cache dtype (production tuning)
# ---------------------------------------------------------------------------
# fp8 reduces KV cache VRAM ~50% with minimal quality loss — recommended for
# production on Ampere+ GPUs (RTX 3090, A100, H100).
# Options: auto, fp8, fp16, bf16  ("auto" uses the model's default)
KV_CACHE_DTYPE=auto

# ---------------------------------------------------------------------------
# Model-specific overrides
# ---------------------------------------------------------------------------
# Mistral models require special tokenizer/config format.
# These are auto-detected by start.sh based on MODEL_ID.

# Maximum images/video per prompt (for multimodal models)
# vLLM 0.19+ requires JSON format. Value must be single-quoted for bash.
# Include "video": 1 to enable native video understanding via vLLM.
LIMIT_MM_PER_PROMPT='{"image": 24, "video": 1}'

# ---------------------------------------------------------------------------
# HuggingFace Configuration
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# Shared media directory (WSL2 path)
# ---------------------------------------------------------------------------
# Must point to the same physical folder as SHARED_MEDIA_DIR in ui/.env.
# Example: if ui/.env has SHARED_MEDIA_DIR=C:\ai-workbench\shared-media
#          then this should be:  /mnt/c/ai-workbench/shared-media
# vLLM reads uploaded files from here directly via file:// URIs.
# No base64 encoding needed when this is set correctly.
SHARED_MEDIA_DIR=/mnt/c/ai-workbench/shared-media
